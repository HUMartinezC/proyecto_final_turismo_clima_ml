# General
PROJECT_NAME=tourism-weather-ml
ENVIRONMENT=dev
AWS_REGION=eu-west-1

# AWS identity/profile
AWS_PROFILE=default
# If using temporary credentials, boto3 will use these and ignore AWS_PROFILE.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 data lake
S3_BUCKET_NAME=
S3_BRONZE_PREFIX=bronze
S3_SILVER_PREFIX=silver
S3_GOLD_PREFIX=gold

# Glue / Athena
GLUE_DATABASE=tourism_weather_dev
ATHENA_WORKGROUP=primary
ATHENA_RESULTS_S3_URI=s3://REPLACE_ME/athena-results/

# RDS MariaDB - test environment
RDS_HOST=
RDS_PORT=3306
RDS_DATABASE=tourism_weather
RDS_USER=
RDS_PASSWORD=
RDS_ENGINE=mariadb
RDS_INSTANCE_IDENTIFIER=tourism-weather-mariadb-dev
RDS_INSTANCE_CLASS=db.t3.micro
RDS_ALLOCATED_STORAGE=20
RDS_PUBLICLY_ACCESSIBLE=true
RDS_SECURITY_GROUP_NAME=tourism-weather-mariadb-public

# DocumentDB
DOCDB_URI=
DOCDB_DATABASE=tourism_weather

# Kafka / Amazon MSK
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_WEATHER=weather_observations
KAFKA_TOPIC_TOURISM=tourism_events

# Lambda
LAMBDA_FUNCTION_NAME=tourism-weather-ingestion
LAMBDA_ROLE_ARN=

# Optional AEMET official weather source. It is never used by the default run;
# launch it explicitly with `--source aemet` if you want this contrast source.
AEMET_API_KEY=
AEMET_BASE_URL=https://opendata.aemet.es/opendata/
# Dates use AEMET format: YYYY-MM-DDTHH:MM:SSUTC. If empty, only the station inventory is downloaded.
AEMET_FROM_DATE=
AEMET_TO_DATE=
# Optional comma-separated station ids. If empty and dates are configured, all stations are requested.
AEMET_STATIONS=
# Split long historical windows into smaller requests.
AEMET_CHUNK_DAYS=15
# Retry transient AEMET connection drops or temporary service errors.
AEMET_RETRY_ATTEMPTS=5
AEMET_RETRY_BASE_SECONDS=3
AEMET_SKIP_EXISTING=true

# Open-Meteo historical weather - default and primary weather source for the MVP.
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_FROM_DATE=2015-10-01
OPEN_METEO_TO_DATE=2024-12-31
# Optional comma-separated province codes, e.g. madrid,barcelona,malaga. Empty means all province capitals.
OPEN_METEO_LOCATIONS=
OPEN_METEO_TIMEZONE=Europe/Madrid
OPEN_METEO_MIN_SECONDS_BETWEEN_REQUESTS=5
OPEN_METEO_RETRY_ATTEMPTS=6
OPEN_METEO_RETRY_BASE_SECONDS=10
OPEN_METEO_SKIP_EXISTING=true

# Generated locally with the Python `holidays` package.
HOLIDAYS_FROM_YEAR=2015
HOLIDAYS_TO_YEAR=2024

DATAESTUR_BASE_URL=https://dataestur.azure-api.net/API-SEGITTUR-v1/
# If empty, the pipeline uses the curated ideal endpoint set for this project.
DATAESTUR_ENDPOINTS=EOH_PROV_DL,EOH_CCAA_DL,FRONTUR_DL,ETR_DL,EGATUR_DL,AENA_DESTINOS_DL,VALORES_CLIMATOLOGICOS_TEMPERATURA_DL,VALORES_CLIMATOLOGICOS_PRECIPITACION_DL
# Default training window: modern tourism, pre-COVID, COVID and recovery.
DATAESTUR_FROM_YEAR=2015
DATAESTUR_FROM_MONTH=10
DATAESTUR_TO_YEAR=2024
DATAESTUR_TO_MONTH=12
# Copy the Request URL generated in https://www.dataestur.es/apidata/ for EOH.
DATAESTUR_EOH_REQUEST_URL=
# Optional extra Dataestur requests: name=https://...;other_name=https://...
# Use this for endpoints that need UI filters, for example IND_RENTABILIDAD_PROVINCIA_DL by province.
DATAESTUR_EXTRA_REQUEST_URLS=
AENA_BASE_URL=
